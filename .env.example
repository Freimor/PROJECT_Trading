# Скопируйте в .env и измените значения перед запуском: copy .env.example .env

# n8n web UI (http://localhost:5678)
N8N_USER=admin
N8N_PASSWORD=changeme

# n8n Public API key (Settings → API keys)
# Required for Telegram "🧩 Workflows" management.
N8N_API_KEY=
# Optional override (default: http://n8n:5678/api/v1)
N8N_API_BASE=http://n8n:5678/api/v1

# Часовой пояс для cron и логов
GENERIC_TIMEZONE=Europe/Moscow

# SQLite
TRADING_DB_PATH=/data/trading.db

# --- Binance testnet (этап 4) ---
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# --- Binance live (этап 8 — только после checklist) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=
LIVE_TRADING_ENABLED=false

# --- T-Invest sandbox / live (этапы 5, 8) ---
# Sandbox: отдельный токен в кабинете T-Bank Invest → Настройки → API
TINKOFF_SANDBOX_TOKEN=
TINKOFF_TOKEN=
# T-Invest обычно ходит напрямую; proxy-gateway нужен только для Telegram.
# Включайте прокси для T-Invest только если tbank.ru недоступен из Docker:
# TINVEST_USE_PROXY_GATEWAY=false
# TINVEST_HTTP_PROXY=socks5://proxy-gateway:17890
# TINVEST_SSL_VERIFY=false

# Папка моделей Ollama на Windows (общая с Docker-контейнером)
# OLLAMA_MODELS_PATH=C:\Users\freim\.ollama

# --- Research monitor (papers/) ---
# Опционально: выше лимиты Semantic Scholar API
# SEMANTIC_SCHOLAR_API_KEY=

# --- Telegram bot (мобильный пульт) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_CHAT_IDS=

# Прокси для Telegram (обязательно если api.telegram.org заблокирован)
# Один прокси:
# TELEGRAM_PROXY=socks5://host.docker.internal:7890
# Несколько — автоматический выбор первого живого:
TELEGRAM_PROXY_LIST=
# Файл со списком (в Docker: /data/telegram_proxies.txt)
TELEGRAM_PROXY_FILE=/data/telegram_proxies.txt
# Опционально: URL со списком прокси (текст, по строке)
# TELEGRAM_PROXY_FETCH_URL=

# awesome-vpn — встроенная подписка (sing-box urltest, по умолчанию включено)
TELEGRAM_AWESOME_VPN_ENABLED=true
TELEGRAM_PROXY_GATEWAY=socks5://proxy-gateway:17890
TELEGRAM_AWESOME_VPN_MAX_NODES=50
TELEGRAM_GATEWAY_PROBE_TIMEOUT_SEC=60

# --- Web console / operator auth ---
# Пароль для смены режимов, kill switch и других опасных действий в консоли
OPERATOR_PASSWORD=
# Устаревший вариант (Telegram bot); консоль предпочитает OPERATOR_PASSWORD
ADMIN_API_KEY=
